---
import PostList from '@components/Posts/List.astro';
import MainSEO from '@components/SEO/Main.astro';
import { Icon } from 'astro-icon/components';

import PageTitle from '@/components/PageTitle.astro';
import MainLayout from '@/layouts/main.astro';
import { getPublishedPosts, sortPostsByPublishedDate } from '@/utils/posts';

const allPosts = sortPostsByPublishedDate(await getPublishedPosts());

// Meta data
const meta = {
	title: 'Posts',
	description:
		'Read Kelvin Chan’s blog posts about software, electronics, university life, projects, and personal reflections.',
};
---

<MainLayout>
    <MainSEO slot="head" includeSiteTitle title={meta.title} description={meta.description} />
    <div class="mb-2">
        <PageTitle
            title="Blog"
            description="Welcome to my blog, where I embark on a journey of sharing knowledge and meaningful insights with the world."
        />
    </div>
    <a
        class="text-neutral-600 dark:text-neutral-400"
        href="/rss.xml"
        aria-label="RSS Feed"
        title="RSS Feed"
    >
        <Icon name="iconoir:rss-feed-tag-solid" size={20} />
    </a>
    <PostList allPosts={allPosts} />
</MainLayout>
