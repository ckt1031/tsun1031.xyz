---
import '@/styles/post.css';

import { getCollection, render } from 'astro:content';
import type { InferGetStaticPropsType } from 'astro';
import readingTimeModule from 'reading-time';

import ArticleSEO from '@/components/SEO/Article.astro';
import MainLayout from '@/layouts/main.astro';
import { formatHongKongDate, formatHongKongISOString } from '@/utils/date';

export async function getStaticPaths() {
	const posts = await getCollection('posts', ({ data }) => !data.draft);

	return posts.map((p) => {
		const readingTime = readingTimeModule(p.body ?? '');
		const readingMinutes =
			readingTime.minutes >= 1
				? `${Math.round(readingTime.minutes)} minutes`
				: 'Less than 1' + ' minute';

		return {
			params: { slug: p.id },
			props: { post: p, readingMinutes },
		};
	});
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post, readingMinutes } = Astro.props;
const { Content } = await render(post);
const publishedTime = formatHongKongISOString(post.data.published);
const modifiedTime = post.data.updated
	? formatHongKongISOString(post.data.updated)
	: undefined;

const publishedHKTAtStr = formatHongKongDate(post.data.published);
const modifiedHKTAtStr = modifiedTime ? formatHongKongDate(modifiedTime) : null;
---

<MainLayout>
  <ArticleSEO
    slot="head"
    includeSiteTitle
    title={post.data.title}
    description={post.data.description}
    author={["ckt1031"]}
    published_time={publishedTime}
    modified_time={modifiedTime}
    tags={post.data.tags || []}
    section={post.data.tags ? post.data.tags[0] : "post"}
    canonical={post.data.canonical}
  />
  <article class="mb-20 mt-5 w-full">
    <div class="base-border border-b">
      <p class="mt-2 text-neutral-600 dark:text-neutral-400">
        {publishedHKTAtStr == modifiedHKTAtStr && `Published at ${publishedHKTAtStr}`}
        {publishedHKTAtStr != modifiedHKTAtStr && `Updated at ${modifiedHKTAtStr}`}
      </p>
      <h1 class="text-3xl wrap-break-word font-bold md:text-4xl">
        {post.data.title}
      </h1>
      <p
        class="mt-3 mb-4 text-slate-600 dark:text-slate-400 text-left"
      >
        Reading: {readingMinutes}
      </p>
    </div>
    <div class="blog-style">
      <Content />
    </div>
    {
      post.data.tags && (
        <div class="base-border mt-7 border-t">
          <div class="mt-5">
            <p class="mb-2 font-medium">Tags:</p>
            {post.data.tags.map((tag: string) => (
              <a class="post-tag " href={`/posts/tags/${tag}`}>
                {tag}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </article>
</MainLayout>
