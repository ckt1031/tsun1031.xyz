---
import { SEO } from 'astro-seo';

import config from '@/config';

interface Props {
	title: string;
	description: string;
	includeSiteTitle?: boolean;
	noindex?: boolean;
}

const { title, description, includeSiteTitle, noindex } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, config.url).toString();
---

<head>
  <SEO
    title={includeSiteTitle ? `${config.siteTitle} - ${title}` : title}
    canonical={canonicalUrl}
    description={description}
    noindex={noindex}
    openGraph={{
      basic: {
        title: title,
        type: "website",
        image: config.siteIconPublicPath,
      },
    }}
    twitter={{
      creator: config.twitter,
      title: title,
      description: description,
    }}
  />
</head>
